# SYNTROFI / NRC Clear — local configuration

# Static humanitarian layers (GeoParquet, PMTiles, manifest)
VITE_DATA_BASE_URL=/data

# CLEAR API — server-side / scripts only (never expose in browser)
# Get a key: https://api.clearinitiative.io/docs#guide
# Bun loads .env.local automatically for `bun run` scripts
CLEAR_API_KEY=sk_your_key_here
